import { ScrollView } from "std-widgets.slint";

export component SettingsWindow inherits Window {
    width: 460px;
    height: 660px;
    title: "CCopy 设置";
    background: #1c1c1e;
    no-frame: true;
    always-on-top: true;

    // 当前快捷键显示文本
    in-out property <string> hotkey_display;
    // 是否正在录制快捷键
    in-out property <bool> hotkey_recording;
    // 开机自启开关
    in-out property <bool> autostart_enabled;
    // 最大历史数输入（空=不限制）
    in-out property <string> max_history_input;
    // 最大保留天数输入（空=不限制）
    in-out property <string> max_age_input;
    // 关于：版本号
    in-out property <string> about_version;
    // 更新检查状态文本
    in-out property <string> update_status;
    // 是否有新版本可更新（控制「立即更新」按钮显隐）
    in-out property <bool> update_available;
    // 是否正在检查/下载更新（按钮禁用）
    in-out property <bool> update_busy;
    // 新版本下载地址（由 Rust 侧填入，点击立即更新时回传）
    in-out property <string> update_url;
    // 统计：总条数
    in-out property <int> stat_total;
    // 统计：有备注条数
    in-out property <int> stat_marked;
    // 统计：文本条数
    in-out property <int> stat_text;
    // 统计：图片条数
    in-out property <int> stat_image;
    // 统计：文件条数
    in-out property <int> stat_files;

    // 当前激活的 tab：0=通用 1=清理 2=同步
    in-out property <int> active_tab;

    // 同步配置（阶段二联动，先占位）
    in-out property <bool> sync_enabled;
    in-out property <string> sync_url;
    in-out property <string> sync_username;
    in-out property <string> sync_password;
    in-out property <bool> sync_image_enabled;
    in-out property <bool> sync_marked_only;
    in-out property <string> sync_retain_months;
    in-out property <string> sync_status;
    // 密码是否明文显示
    in-out property <bool> sync_password_visible;

    callback close_requested();
    // 手动检查更新
    callback check_update();
    // 立即更新（下载并安装）
    callback do_update(string);
    callback drag_started();
    callback dragged();
    callback start_record();
    // 录制到按键：key文本 / ctrl / alt / shift
    callback hotkey_recorded(string, bool, bool, bool);
    callback toggle_autostart();
    // 应用自动清理规则（最大记录数 + 最大保留天数）
    callback apply_cleanup_rules();

    // 同步配置变更回调（阶段二接入）
    callback apply_sync_config();
    callback sync_now();
    callback test_connection();
    // 打开外部链接（浏览器）
    callback open_url(string);

    // 二次确认弹层：当前无弹层、待确认清空未标记、待确认清空全部
    in-out property <string> confirm_kind; // "" / "unnoted" / "all"
    // 倒计时剩余秒数（>0 时确认按钮禁用）
    in-out property <int> confirm_countdown;
    callback confirm_cancel();
    callback confirm_accept();

    // Toast 通知：show_toast 回调触发，toast_message/toast_visible 驱动浮层显示
    // toast_kind: "info" | "success" | "error"，控制颜色
    callback show_toast(string, string);
    in-out property <string> toast_message;
    in-out property <string> toast_kind;
    in-out property <bool> toast_visible;
    property <length> toast_timer;

    focus_scope := FocusScope {
        key-pressed(event) => {
            // 录制中：捕获非纯修饰键，Escape 取消录制
            if root.hotkey_recording {
                if event.text == Key.Escape {
                    root.hotkey_recording = false;
                    accept
                } else if event.text == Key.Control || event.text == Key.Alt || event.text == Key.Shift || event.text == Key.Meta {
                    reject
                } else {
                    root.hotkey_recorded(
                        event.text,
                        event.modifiers.control,
                        event.modifiers.alt,
                        event.modifiers.shift,
                    );
                    accept
                }
            } else if event.text == Key.Escape {
                root.close_requested();
                accept
            } else {
                reject
            }
        }
        Rectangle {
            drag_area := TouchArea {
                moved => {
                    if (self.pressed) {
                        root.dragged();
                    }
                }
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        root.drag_started();
                    }
                }
            }

            VerticalLayout {
                padding: 20px;
                spacing: 16px;

                // 标题栏
                Rectangle {
                    height: 36px;

                    Text {
                        x: 0;
                        text: "设置";
                        color: #f5f5f7;
                        font-size: 18px;
                        font-weight: 700;
                        letter-spacing: -0.02rem;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        x: parent.width - 36px;
                        width: 36px;
                        height: 36px;
                        border-radius: 10px;
                        background: settings_close.has-hover ? #3a3a3c : transparent;

                        settings_close := TouchArea {
                            clicked => {
                                root.close_requested();
                            }
                        }

                        Image {
                            x: 11px;
                            y: 11px;
                            width: 14px;
                            height: 14px;
                            colorize: #8e8e93;
                            source: @image-url("../../assets/icons/x.svg");
                        }
                    }
                }

                // Tab 栏：分段控件
                Rectangle {
                    height: 36px;
                    border-radius: 10px;
                    background: #2c2c2e;
                    border-width: 1px;
                    border-color: #3a3a3c;

                    HorizontalLayout {
                        padding: 3px;
                        spacing: 3px;

                        tab-general := Rectangle {
                            horizontal-stretch: 1;
                            height: 30px;
                            border-radius: 8px;
                            background: root.active_tab == 0 ? #3a3a3c : transparent;

                            TouchArea {
                                clicked => {
                                    root.active_tab = 0;
                                }
                            }

                            Text {
                                text: "通用";
                                color: root.active_tab == 0 ? #f5f5f7 : #8e8e93;
                                font-size: 13px;
                                font-weight: root.active_tab == 0 ? 600 : 400;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        tab-cleanup := Rectangle {
                            horizontal-stretch: 1;
                            height: 30px;
                            border-radius: 8px;
                            background: root.active_tab == 1 ? #3a3a3c : transparent;

                            TouchArea {
                                clicked => {
                                    root.active_tab = 1;
                                }
                            }

                            Text {
                                text: "清理";
                                color: root.active_tab == 1 ? #f5f5f7 : #8e8e93;
                                font-size: 13px;
                                font-weight: root.active_tab == 1 ? 600 : 400;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        tab-sync := Rectangle {
                            horizontal-stretch: 1;
                            height: 30px;
                            border-radius: 8px;
                            background: root.active_tab == 2 ? #3a3a3c : transparent;

                            TouchArea {
                                clicked => {
                                    root.active_tab = 2;
                                }
                            }

                            Text {
                                text: "同步";
                                color: root.active_tab == 2 ? #f5f5f7 : #8e8e93;
                                font-size: 13px;
                                font-weight: root.active_tab == 2 ? 600 : 400;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // 内容区
                Rectangle {
                    vertical-stretch: 1;

                    // ===== 通用 Tab =====
                    if root.active_tab == 0: ScrollView {
                        x: 0;
                        y: 0;
                        width: 100%;
                        height: 100%;

                        VerticalLayout {
                            spacing: 20px;

                            VerticalLayout {
                                // 快捷键
                                spacing: 10px;

                                Text {
                                    text: "唤起快捷键";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                }

                                Rectangle {
                                    height: 40px;
                                    border-radius: 10px;
                                    background: #2c2c2e;
                                    border-width: 1px;
                                    border-color: root.hotkey_recording ? #007aff : #3a3a3c;

                                    HorizontalLayout {
                                        padding-left: 14px;
                                        padding-right: 10px;
                                        spacing: 8px;

                                        Text {
                                            text: root.hotkey_recording ? "按下新的快捷键…" : root.hotkey_display;
                                            color: root.hotkey_recording ? #007aff : #f5f5f7;
                                            font-size: 14px;
                                            vertical-alignment: center;
                                            horizontal-alignment: left;
                                        }

                                        Rectangle {
                                            width: 64px;
                                            height: 30px;
                                            y: (parent.height - self.height) / 2;
                                            border-radius: 8px;
                                            background: record_btn.has-hover ? #3a3a3c : #1c1c1e;

                                            record_btn := TouchArea {
                                                clicked => {
                                                    root.start_record();
                                                }
                                            }

                                            Text {
                                                text: "录制";
                                                color: #aeaeb2;
                                                font-size: 13px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }

                            HorizontalLayout {
                                // 开机自启
                                height: 32px;
                                spacing: 8px;

                                Text {
                                    text: "开机自启动";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                Rectangle {
                                    // 苹果风格开关
                                    width: 48px;
                                    height: 28px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 14px;
                                    background: root.autostart_enabled ? #34c759 : #3a3a3c;

                                    autostart_toggle := TouchArea {
                                        clicked => {
                                            root.toggle_autostart();
                                        }
                                    }

                                    Rectangle {
                                        x: root.autostart_enabled ? (parent.width - self.width - 3px) : 3px;
                                        y: 3px;
                                        width: 22px;
                                        height: 22px;
                                        border-radius: 11px;
                                        background: #ffffff;
                                    }
                                }
                            }

                            Rectangle {
                                // 分隔线
                                height: 1px;
                                background: #2c2c2e;
                            }

                            VerticalLayout {
                                // 统计
                                spacing: 10px;

                                Text {
                                    text: "统计";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                }

                                HorizontalLayout {
                                // 总条数 + 有备注条数
                                    spacing: 10px;

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 56px;
                                        border-radius: 10px;
                                        background: #2c2c2e;
                                        border-width: 1px;
                                        border-color: #3a3a3c;

                                        VerticalLayout {
                                            padding: 8px;
                                            spacing: 2px;

                                            Text {
                                                text: "总条数";
                                                color: #8e8e93;
                                                font-size: 11px;
                                            }

                                            Text {
                                                text: root.stat_total;
                                                color: #f5f5f7;
                                                font-size: 18px;
                                                font-weight: 700;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 56px;
                                        border-radius: 10px;
                                        background: #2c2c2e;
                                        border-width: 1px;
                                        border-color: #3a3a3c;

                                        VerticalLayout {
                                            padding: 8px;
                                            spacing: 2px;

                                            Text {
                                                text: "有备注";
                                                color: #8e8e93;
                                                font-size: 11px;
                                            }

                                            Text {
                                                text: root.stat_marked;
                                                color: #f5f5f7;
                                                font-size: 18px;
                                                font-weight: 700;
                                            }
                                        }
                                    }
                                }

                                HorizontalLayout {
                                // 各分类条数
                                    spacing: 10px;

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 56px;
                                        border-radius: 10px;
                                        background: #2c2c2e;
                                        border-width: 1px;
                                        border-color: #3a3a3c;

                                        VerticalLayout {
                                            padding: 8px;
                                            spacing: 2px;

                                            Text {
                                                text: "文本";
                                                color: #8e8e93;
                                                font-size: 11px;
                                            }

                                            Text {
                                                text: root.stat_text;
                                                color: #f5f5f7;
                                                font-size: 18px;
                                                font-weight: 700;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 56px;
                                        border-radius: 10px;
                                        background: #2c2c2e;
                                        border-width: 1px;
                                        border-color: #3a3a3c;

                                        VerticalLayout {
                                            padding: 8px;
                                            spacing: 2px;

                                            Text {
                                                text: "图片";
                                                color: #8e8e93;
                                                font-size: 11px;
                                            }

                                            Text {
                                                text: root.stat_image;
                                                color: #f5f5f7;
                                                font-size: 18px;
                                                font-weight: 700;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 56px;
                                        border-radius: 10px;
                                        background: #2c2c2e;
                                        border-width: 1px;
                                        border-color: #3a3a3c;

                                        VerticalLayout {
                                            padding: 8px;
                                            spacing: 2px;

                                            Text {
                                                text: "文件";
                                                color: #8e8e93;
                                                font-size: 11px;
                                            }

                                            Text {
                                                text: root.stat_files;
                                                color: #f5f5f7;
                                                font-size: 18px;
                                                font-weight: 700;
                                            }
                                        }
                                    }
                                }
                            }

                            VerticalLayout {
                            // 更新
                                spacing: 10px;

                                Text {
                                    text: "更新";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: root.update_status;
                                        color: #6e6e73;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }

                                    Rectangle {
                                    // 检查更新按钮
                                        width: 80px;
                                        height: 30px;
                                        border-radius: 8px;
                                        background: check_btn.has-hover ? #3a3a3c : #2c2c2e;
                                        border-width: 1px;
                                        border-color: #48484a;

                                        check_btn := TouchArea {
                                            enabled: !root.update_busy;
                                            clicked => {
                                                root.check_update();
                                            }
                                        }

                                        Text {
                                            text: "检查更新";
                                            color: root.update_busy ? #48484a : #aeaeb2;
                                            font-size: 12px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    // 立即更新按钮
                                    if root.update_available: Rectangle {
                                        width: 80px;
                                        height: 30px;
                                        border-radius: 8px;
                                        background: do_update_btn.has-hover ? #2e8dff : #007aff;

                                        do_update_btn := TouchArea {
                                            enabled: !root.update_busy;
                                            clicked => {
                                                root.do_update(root.update_url);
                                            }
                                        }

                                        Text {
                                            text: "立即更新";
                                            color: #ffffff;
                                            font-size: 12px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                            }

                            Rectangle {
                                // 分隔线
                                height: 1px;
                                background: #2c2c2e;
                            }


                            // 关于
                            HorizontalLayout {
                                spacing: 8px;

                                Text {
                                    text: "CCopy " + root.about_version;
                                    color: #6e6e73;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: "轻量级剪贴板历史工具";
                                    color: #48484a;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // ===== 清理 Tab =====
                    if root.active_tab == 1: ScrollView {
                        x: 0;
                        y: 0;
                        width: 100%;
                        height: 100%;

                        VerticalLayout {
                            spacing: 20px;
                            alignment: start;

                            VerticalLayout {
                                // 自动清理规则
                                spacing: 10px;

                                Text {
                                    text: "自动清理规则";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                }

                                Text {
                                    text: "留空 = 不限制 · 添加备注的记录不会被自动清理";
                                    color: #6e6e73;
                                    font-size: 12px;
                                }

                                HorizontalLayout {
                                    // 最大记录数
                                    spacing: 10px;

                                    Text {
                                        text: "最大记录数";
                                        color: #8e8e93;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        width: 80px;
                                    }

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 38px;
                                        border-radius: 10px;
                                        background: #2c2c2e;
                                        border-width: 1px;
                                        border-color: #3a3a3c;

                                        TextInput {
                                            x: 14px;
                                            width: parent.width - 28px;
                                            height: 100%;
                                            vertical-alignment: center;
                                            text <=> root.max_history_input;
                                            color: #f5f5f7;
                                            font-size: 14px;
                                            input-type: number;

                                            key-pressed(event) => {
                                                if event.text == Key.Return {
                                                    root.apply_cleanup_rules();
                                                    accept
                                                } else {
                                                    reject
                                                }
                                            }
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    // 最大保留天数
                                    spacing: 10px;

                                    Text {
                                        text: "保留天数";
                                        color: #8e8e93;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        width: 80px;
                                    }

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 38px;
                                        border-radius: 10px;
                                        background: #2c2c2e;
                                        border-width: 1px;
                                        border-color: #3a3a3c;

                                        TextInput {
                                            x: 14px;
                                            width: parent.width - 28px;
                                            height: 100%;
                                            vertical-alignment: center;
                                            text <=> root.max_age_input;
                                            color: #f5f5f7;
                                            font-size: 14px;
                                            input-type: number;

                                            key-pressed(event) => {
                                                if event.text == Key.Return {
                                                    root.apply_cleanup_rules();
                                                    accept
                                                } else {
                                                    reject
                                                }
                                            }
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    // 应用按钮
                                    alignment: end;

                                    Rectangle {
                                        width: 80px;
                                        height: 32px;
                                        border-radius: 8px;
                                        background: apply_rules_btn.has-hover ? #3a3a3c : #2c2c2e;
                                        border-width: 1px;
                                        border-color: #48484a;

                                        apply_rules_btn := TouchArea {
                                            clicked => {
                                                root.apply_cleanup_rules();
                                            }
                                        }

                                        Text {
                                            text: "应用";
                                            color: #aeaeb2;
                                            font-size: 13px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                // 分隔线
                                height: 1px;
                                background: #2c2c2e;
                            }

                            VerticalLayout {
                                // 手动清理
                                spacing: 10px;

                                Text {
                                    text: "手动清理";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                }

                                Rectangle {
                                // 清空未标记记录
                                    height: 38px;
                                    border-radius: 10px;
                                    background: clear_unnoted_btn.has-hover ? #3a3a3c : #2c2c2e;
                                    border-width: 1px;
                                    border-color: #48484a;

                                    clear_unnoted_btn := TouchArea {
                                        clicked => {
                                            root.confirm_kind = "unnoted";
                                            root.confirm_countdown = 2;
                                        }
                                    }

                                    Text {
                                        text: "清空未标记记录";
                                        color: #aeaeb2;
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                // 清空全部记录（危险操作）
                                    height: 38px;
                                    border-radius: 10px;
                                    background: clear_all_btn.has-hover ? #4a1a28 : #3a1520;
                                    border-width: 1px;
                                    border-color: #5a2030;

                                    clear_all_btn := TouchArea {
                                        clicked => {
                                            root.confirm_kind = "all";
                                            root.confirm_countdown = 2;
                                        }
                                    }

                                    Text {
                                        text: "清空全部记录（含备注）";
                                        color: #ff453a;
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // ===== 同步 Tab =====
                    if root.active_tab == 2: ScrollView {
                        x: 0;
                        y: 0;
                        width: 100%;
                        height: 100%;

                        VerticalLayout {
                            spacing: 16px;
                            alignment: start;

                            HorizontalLayout {
                                // 启用同步
                                height: 32px;
                                spacing: 8px;

                                Text {
                                    text: "启用同步";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                Rectangle {
                                    width: 48px;
                                    height: 28px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 14px;
                                    background: root.sync_enabled ? #34c759 : #3a3a3c;

                                    sync_toggle := TouchArea {
                                        clicked => {
                                            root.sync_enabled = !root.sync_enabled;
                                            root.apply_sync_config();
                                        }
                                    }

                                    Rectangle {
                                        x: root.sync_enabled ? (parent.width - self.width - 3px) : 3px;
                                        y: 3px;
                                        width: 22px;
                                        height: 22px;
                                        border-radius: 11px;
                                        background: #ffffff;
                                    }
                                }
                            }

                            VerticalLayout {
                                // WebDAV 地址
                                spacing: 8px;

                                HorizontalLayout {
                                    Text {
                                        text: "WebDAV 地址";
                                        color: #aeaeb2;
                                        font-size: 13px;
                                        font-weight: 500;
                                    }

                                    // 示例地址：靠右，点击打开浏览器
                                    Rectangle {
                                        height: 16px;
                                        width: 100%;

                                        url_example := TouchArea {
                                            clicked => {
                                                root.open_url("https://help.jianguoyun.com/?p=2064");
                                            }
                                        }

                                        Text {
                                            text: "示例：https://dav.jianguoyun.com/dav/CCopy";
                                            color: url_example.has-hover ? #007aff : #6e6e73;
                                            font-size: 11px;
                                        }
                                    }
                                }

                                Rectangle {
                                    height: 38px;
                                    border-radius: 10px;
                                    background: #2c2c2e;
                                    border-width: 1px;
                                    border-color: #3a3a3c;

                                    TextInput {
                                        x: 14px;
                                        width: parent.width - 28px;
                                        height: 100%;
                                        vertical-alignment: center;
                                        text <=> root.sync_url;
                                        color: #f5f5f7;
                                        font-size: 14px;
                                    }
                                }
                            }

                            VerticalLayout {
                                // 用户名
                                spacing: 8px;

                                Text {
                                    text: "用户名";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                }

                                Rectangle {
                                    height: 38px;
                                    border-radius: 10px;
                                    background: #2c2c2e;
                                    border-width: 1px;
                                    border-color: #3a3a3c;

                                    TextInput {
                                        x: 14px;
                                        width: parent.width - 28px;
                                        height: 100%;
                                        vertical-alignment: center;
                                        text <=> root.sync_username;
                                        color: #f5f5f7;
                                        font-size: 14px;
                                    }
                                }
                            }

                            VerticalLayout {
                                // 密码
                                spacing: 8px;

                                Text {
                                    text: "密码";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                }

                                Rectangle {
                                    height: 38px;
                                    border-radius: 10px;
                                    background: #2c2c2e;
                                    border-width: 1px;
                                    border-color: #3a3a3c;

                                    // 隐藏态：密码遮罩
                                    if !root.sync_password_visible: TextInput {
                                        x: 14px;
                                        width: parent.width - 60px;
                                        height: 100%;
                                        vertical-alignment: center;
                                        text <=> root.sync_password;
                                        color: #f5f5f7;
                                        font-size: 14px;
                                        input-type: password;
                                    }

                                    // 显示态：明文
                                    if root.sync_password_visible: TextInput {
                                        x: 14px;
                                        width: parent.width - 60px;
                                        height: 100%;
                                        vertical-alignment: center;
                                        text <=> root.sync_password;
                                        color: #f5f5f7;
                                        font-size: 14px;
                                    }

                                    // 显隐切换按钮（图标）
                                    Rectangle {
                                        x: parent.width - 42px;
                                        y: (parent.height - 26px) / 2;
                                        width: 30px;
                                        height: 26px;
                                        border-radius: 6px;
                                        background: pwd_toggle.has-hover ? #3a3a3c : transparent;

                                        pwd_toggle := TouchArea {
                                            clicked => {
                                                root.sync_password_visible = !root.sync_password_visible;
                                            }
                                        }

                                        Image {
                                            x: (parent.width - 14px) / 2;
                                            y: (parent.height - 14px) / 2;
                                            width: 14px;
                                            height: 14px;
                                            colorize: #8e8e93;
                                            source: root.sync_password_visible ? @image-url("../../assets/icons/eye-off.svg") : @image-url("../../assets/icons/eye.svg");
                                        }
                                    }
                                }
                            }

                            // 仅同步标记内容开关（默认开启，大幅减少流量）
                            // 仅控制文本类，图片由「同步图片」开关独立控制
                            VerticalLayout {
                                spacing: 2px;

                                HorizontalLayout {
                                    height: 32px;
                                    spacing: 8px;

                                    Text {
                                        text: "仅同步标记内容";
                                        color: #aeaeb2;
                                        font-size: 13px;
                                        font-weight: 500;
                                        vertical-alignment: center;
                                    }

                                    Rectangle {
                                        horizontal-stretch: 1;
                                    }

                                    Rectangle {
                                        width: 48px;
                                        height: 28px;
                                        y: (parent.height - self.height) / 2;
                                        border-radius: 14px;
                                        background: root.sync_marked_only ? #34c759 : #3a3a3c;

                                        sync_marked_toggle := TouchArea {
                                            clicked => {
                                                root.sync_marked_only = !root.sync_marked_only;
                                                root.apply_sync_config();
                                            }
                                        }

                                        Rectangle {
                                            x: root.sync_marked_only ? (parent.width - self.width - 3px) : 3px;
                                            y: 3px;
                                            width: 22px;
                                            height: 22px;
                                            border-radius: 11px;
                                            background: #ffffff;
                                        }
                                    }
                                }

                                Text {
                                    text: "开启后文本类需有备注才同步，图片不受此限制";
                                    color: #636366;
                                    font-size: 11px;
                                }
                            }

                            HorizontalLayout {
                                // 图片同步开关
                                height: 32px;
                                spacing: 8px;

                                Text {
                                    text: "同步图片";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                Rectangle {
                                    width: 48px;
                                    height: 28px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 14px;
                                    background: root.sync_image_enabled ? #34c759 : #3a3a3c;

                                    sync_img_toggle := TouchArea {
                                        clicked => {
                                            root.sync_image_enabled = !root.sync_image_enabled;
                                            root.apply_sync_config();
                                        }
                                    }

                                    Rectangle {
                                        x: root.sync_image_enabled ? (parent.width - self.width - 3px) : 3px;
                                        y: 3px;
                                        width: 22px;
                                        height: 22px;
                                        border-radius: 11px;
                                        background: #ffffff;
                                    }
                                }
                            }

                            VerticalLayout {
                                // 保留期
                                spacing: 8px;

                                Text {
                                    text: "保留期（月）";
                                    color: #aeaeb2;
                                    font-size: 13px;
                                    font-weight: 500;
                                }

                                Rectangle {
                                    height: 38px;
                                    border-radius: 10px;
                                    background: #2c2c2e;
                                    border-width: 1px;
                                    border-color: #3a3a3c;

                                    TextInput {
                                        x: 14px;
                                        width: parent.width - 28px;
                                        height: 100%;
                                        vertical-alignment: center;
                                        text <=> root.sync_retain_months;
                                        color: #f5f5f7;
                                        font-size: 14px;
                                        input-type: number;
                                    }
                                }
                            }

                            HorizontalLayout {
                                // 应用 + 测试连接 + 立即同步
                                spacing: 10px;
                                alignment: end;

                                Rectangle {
                                    width: 80px;
                                    height: 32px;
                                    border-radius: 8px;
                                    background: apply_sync_btn.has-hover ? #3a3a3c : #2c2c2e;
                                    border-width: 1px;
                                    border-color: #48484a;

                                    apply_sync_btn := TouchArea {
                                        clicked => {
                                            root.apply_sync_config();
                                        }
                                    }

                                    Text {
                                        text: "应用";
                                        color: #aeaeb2;
                                        font-size: 13px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    width: 90px;
                                    height: 32px;
                                    border-radius: 8px;
                                    background: test_conn_btn.has-hover ? #3a5a3a : #2a4a2a;
                                    border-width: 1px;
                                    border-color: #34c759;

                                    test_conn_btn := TouchArea {
                                        clicked => {
                                            root.test_connection();
                                        }
                                    }

                                    Text {
                                        text: "测试连接";
                                        color: #34c759;
                                        font-size: 13px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    width: 90px;
                                    height: 32px;
                                    border-radius: 8px;
                                    background: sync_now_btn.has-hover ? #2e8dff : #007aff;

                                    sync_now_btn := TouchArea {
                                        clicked => {
                                            root.sync_now();
                                        }
                                    }

                                    Text {
                                        text: "立即同步";
                                        color: #ffffff;
                                        font-size: 13px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Rectangle {
                            //     // 状态指示
                            //     height: 32px;
                            //     border-radius: 8px;
                            //     background: #2c2c2e;
                            //     border-width: 1px;
                            //     border-color: #3a3a3c;

                            //     Text {
                            //         text: root.sync_status == "" ? "未连接" : root.sync_status;
                            //         color: #6e6e73;
                            //         font-size: 12px;
                            //         horizontal-alignment: center;
                            //         vertical-alignment: center;
                            //         width: 100%;
                            //     }
                            // }
                        }
                    }
                }
            }
        }
    }

    // 倒计时定时器
    confirm_timer := Timer {
        interval: 1s;
        running: root.confirm_kind != "" && root.confirm_countdown > 0;
        triggered => {
            if (root.confirm_countdown > 0) {
                root.confirm_countdown -= 1;
            }
        }
    }

    // 二次确认弹层
    if root.confirm_kind != "": Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        background: #00000088;

        TouchArea {
            clicked => {
                root.confirm_cancel();
            }
        }

        Rectangle {
            x: (parent.width - 320px) / 2;
            y: (parent.height - 150px) / 2;
            width: 320px;
            height: 150px;
            background: #2c2c2e;
            border-radius: 14px;
            border-width: 1px;
            border-color: #3a3a3c;

            TouchArea { }

            Text {
                x: 24px;
                y: 24px;
                width: parent.width - 48px;
                text: root.confirm_kind == "all" ? "将清空全部记录（含备注），不可恢复，确认？" : "将清空所有未标记记录，确认？";
                color: #f5f5f7;
                font-size: 14px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            // 取消按钮
            Rectangle {
                x: 36px;
                y: 96px;
                width: 110px;
                height: 36px;
                background: cancel_confirm_btn.has-hover ? #3a3a3c : #1c1c1e;
                border-radius: 10px;
                border-width: 1px;
                border-color: #48484a;

                cancel_confirm_btn := TouchArea {
                    clicked => {
                        root.confirm_cancel();
                    }
                }

                Text {
                    text: "取消";
                    color: #aeaeb2;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // 确认按钮
            Rectangle {
                x: 174px;
                y: 96px;
                width: 110px;
                height: 36px;
                background: root.confirm_countdown > 0 ? #3a1520 : (ok_confirm_btn.has-hover ? #5a2030 : #4a1a28);
                border-radius: 10px;

                ok_confirm_btn := TouchArea {
                    enabled: root.confirm_countdown == 0;
                    clicked => {
                        root.confirm_accept();
                    }
                }

                Text {
                    text: root.confirm_countdown > 0 ? "确认 (" + root.confirm_countdown + "s)" : "确认";
                    color: #ff453a;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    // Toast 浮层：固定在窗口底部居中，显示 2 秒后自动隐藏
    // z-index 最高的浮层，覆盖所有内容
    if root.toast_visible : Rectangle {
        // 背景半透明遮罩，点击不穿透但也不阻断（仅视觉聚焦 toast）
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 40px;
        width: min(parent.width - 40px, 360px);
        height: 44px;
        border-radius: 10px;
        // 根据 toast_kind 切换颜色：success 绿、error 红、info 灰
        background: root.toast_kind == "success" ? #1a4d2e
            : root.toast_kind == "error" ? #4d1a1a
            : #2c2c2e;
        border-width: 1px;
        border-color: root.toast_kind == "success" ? #34c759
            : root.toast_kind == "error" ? #ff453a
            : #48484a;

        Text {
            x: 16px;
            width: parent.width - 32px;
            height: 100%;
            text: root.toast_message;
            color: #f5f5f7;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // 录制开始时聚焦 FocusScope
    init => {
        focus_scope.focus();
    }
}
