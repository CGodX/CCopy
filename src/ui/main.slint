import { ScrollView } from "std-widgets.slint";
import { SettingsWindow } from "settings.slint";

// 重新导出设置窗口组件，使其在生成代码中可用
export { SettingsWindow }

export struct HistoryItem {
    id: int,
    text: string,
    note: string,
    thumbnail: image,
    has_thumbnail: bool,
    blob_path: string,
}

// 分类元数据：由 Rust 侧填充，驱动按钮渲染与键盘循环
export struct CategoryDef {
    id: string,
    label: string,
}

export component MainWindow inherits Window {
    width: 400px;
    height: 560px;
    title: "CCopy";
    background: #1c1c1e;
    no-frame: true;
    always-on-top: true;

    callback hide_requested();
    callback item_selected(int);
    callback item_deleted(int);
    callback search_changed(string);
    callback category_changed(string);
    callback cycle_category(int);
    callback move_selection(int);
    callback confirm_selection();
    callback panel_opened();
    callback focus_search();
    callback load_more();
    callback drag_started();
    callback dragged();
    in-out property <string> search_text;
    in-out property <string> selected_category;
    in property <[CategoryDef]> categories;
    in-out property <int> selected_id;
    in property <[HistoryItem]> history;
    in-out property <length> viewport-y;
    out property <length> visible-height: history_view.visible-height;
    out property <length> content-height: history_view.viewport-height;

    in-out property <string> edit_note_text;
    in-out property <int> edit_note_id;
    in-out property <int> edit_note_row_index;
    in-out property <int> hovered_id: -1;
    in-out property <image> selected_full_image;
    callback open_edit_note(int);
    callback item_hovered(int);
    callback edit_note_confirm(int, string);
    callback edit_note_cancel();
    callback edit_selected_note();

    // 打开设置面板
    callback open_settings();

    focus_search => {
        search_input.focus();
    }

    // 滚动到底部检测：定时检查 viewport-y，接近底部触发加载更多
    load_more_timer := Timer {
        interval: 200ms;
        running: root.visible-height > 0 && root.content-height > 0 && (-root.viewport-y + root.visible-height >= root.content-height - 200px) && root.content-height > root.visible-height;
        triggered => {
            root.load_more();
        }
    }

    open_edit_note(row_index) => {
        root.edit_note_row_index = row_index;
        root.edit_note_id = root.history[row_index].id;
        root.edit_note_text = root.history[row_index].note;
    }

    Rectangle {
        drag_area := TouchArea {
            moved => {
                if (self.pressed) {
                    root.dragged();
                }
            }
            pointer-event(event) => {
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    root.drag_started();
                }
            }
        }

        FocusScope {
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.hide_requested();
                    accept
                } else if (event.text == Key.Return) {
                    root.confirm_selection();
                    accept
                } else if (event.text == Key.DownArrow) {
                    if root.history.length > 0 {
                        root.move_selection(1);
                    }
                    accept
                } else if (event.text == Key.UpArrow) {
                    if root.history.length > 0 {
                        root.move_selection(-1);
                    }
                    accept
                } else if (event.modifiers.alt && event.text == Key.RightArrow) {
                    root.cycle_category(1);
                    accept
                } else if (event.modifiers.alt && event.text == Key.LeftArrow) {
                    root.cycle_category(-1);
                    accept
                } else if (event.text == Key.Delete) {
                    if root.selected_id > 0 {
                        root.item_deleted(root.selected_id);
                    }
                    accept
                } else if (event.text == Key.F2) {
                    if root.selected_id > 0 {
                        root.edit_selected_note();
                    }
                    accept
                } else {
                    reject
                }
            }
        }

        VerticalLayout {
            padding: 16px;
            spacing: 14px;

            // 标题栏
            Rectangle {
                height: 36px;
                background: transparent;

                Text {
                    x: 0;
                    text: "CCopy";
                    color: #f5f5f7;
                    font-size: 20px;
                    font-weight: 700;
                    letter-spacing: -0.02rem;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                }

                // 设置按钮
                Rectangle {
                    x: parent.width - 72px;
                    width: 36px;
                    height: 36px;
                    border-radius: 10px;
                    background: settings_area.has-hover ? #3a3a3c : transparent;

                    settings_area := TouchArea {
                        clicked => {
                            root.open_settings();
                        }
                    }

                    Image {
                        x: 11px;
                        y: 11px;
                        width: 14px;
                        height: 14px;
                        colorize: #8e8e93;
                        source: @image-url("../../assets/icons/settings.svg");
                    }
                }

                // 关闭按钮
                Rectangle {
                    x: parent.width - 36px;
                    width: 36px;
                    height: 36px;
                    border-radius: 10px;
                    background: close_area.has-hover ? #3a3a3c : transparent;

                    close_area := TouchArea {
                        clicked => {
                            root.hide_requested();
                        }
                    }

                    Image {
                        x: 11px;
                        y: 11px;
                        width: 14px;
                        height: 14px;
                        colorize: #8e8e93;
                        source: @image-url("../../assets/icons/x.svg");
                    }
                }
            }

            // 搜索栏
            search_area := Rectangle {
                height: 38px;
                border-radius: 10px;
                background: #2c2c2e;
                border-width: 1px;
                border-color: #3a3a3c;

                search_input := TextInput {
                    height: 100%;
                    x: 14px;
                    width: parent.width - 44px;
                    vertical-alignment: center;
                    text <=> root.search_text;
                    font-size: 14px;
                    color: #f5f5f7;
                    edited => {
                        root.search_changed(self.text);
                    }

                    key-pressed(event) => {
                        if (event.text == Key.DownArrow) {
                            if root.history.length > 0 {
                                root.move_selection(1);
                            }
                            accept
                        } else if (event.text == Key.UpArrow) {
                            if root.history.length > 0 {
                                root.move_selection(-1);
                            }
                            accept
                        } else if (event.modifiers.alt && event.text == Key.RightArrow) {
                            root.cycle_category(1);
                            accept
                        } else if (event.modifiers.alt && event.text == Key.LeftArrow) {
                            root.cycle_category(-1);
                            accept
                        } else if (event.text == Key.Return) {
                            root.confirm_selection();
                            accept
                        } else if (event.text == Key.Escape) {
                            root.hide_requested();
                            accept
                        } else if (event.text == Key.Delete) {
                            if root.selected_id > 0 {
                                root.item_deleted(root.selected_id);
                            }
                            accept
                        } else if (event.text == Key.F2) {
                            if root.selected_id > 0 {
                                root.edit_selected_note();
                            }
                            accept
                        } else {
                            reject
                        }
                    }
                }

                // 清除按钮
                Rectangle {
                    x: parent.width - 28px;
                    y: (parent.height - 20px) / 2;
                    width: 20px;
                    height: 20px;
                    background: search_clear_btn.has-hover ? #48484a : transparent;
                    border-radius: 10px;
                    visible: search_input.text != "";

                    search_clear_btn := TouchArea {
                        clicked => {
                            root.search_text = "";
                            root.search_changed("");
                        }
                    }

                    Image {
                        x: 4px;
                        y: 4px;
                        width: 12px;
                        height: 12px;
                        colorize: #8e8e93;
                        source: @image-url("../../assets/icons/x.svg");
                    }
                }
            }

            // 分类标签栏
            HorizontalLayout {
                height: 32px;
                spacing: 8px;

                for cat in root.categories: Rectangle {
                    min-width: 56px;
                    height: 32px;
                    border-radius: 16px;
                    background: root.selected_category == cat.id ? #007aff : (cat_touch.has-hover ? #3a3a3c : #2c2c2e);

                    cat_touch := TouchArea {
                        clicked => {
                            root.selected_category = cat.id;
                            root.category_changed(cat.id);
                        }
                    }

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 4px;

                        Text {
                            text: cat.label;
                            color: root.selected_category == cat.id ? #ffffff : #aeaeb2;
                            font-size: 13px;
                            font-weight: root.selected_category == cat.id ? 600 : 400;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // 空状态提示
            if root.history.length == 0: Text {
                text: "复制一段文本后，按 Alt+V 在这里选择历史记录。";
                color: #6e6e73;
                font-size: 14px;
                wrap: word-wrap;
                vertical-alignment: center;
                horizontal-alignment: center;
                width: 100%;
            }

            // 历史记录列表
            history_view := ScrollView {
                viewport-width: 368px;
                viewport-y <=> root.viewport-y;

                VerticalLayout {
                    width: 368px;
                    spacing: 8px;

                    for item[index] in root.history: Rectangle {
                        height: 85px;
                        border-radius: 12px;
                        // 苹果风格：用微妙边框代替纯色块
                        border-width: 1px;
                        border-color: item.id == root.selected_id ? #007aff40 : #3a3a3c;
                        background: item.id == root.selected_id ? #007aff15 : (touch.has-hover ? #2c2c2e : #1c1c1e);

                        touch := TouchArea {
                            pointer-event(event) => {
                                if event.kind == PointerEventKind.move {
                                    root.item_hovered(item.id);
                                }
                            }
                            clicked => {
                                root.item_selected(item.id);
                            }
                        }

                        // 缩略图
                        if item.has_thumbnail: Rectangle {
                            x: 10px;
                            y: 7px;
                            width: 66px;
                            height: 66px;
                            border-radius: 8px;
                            clip: true;
                            background: #2c2c2e;

                            Image {
                                width: 66px;
                                height: 66px;
                                source: item.thumbnail;
                                image-fit: preserve;
                            }
                        }

                        // 文本内容
                        Rectangle {
                            x: item.has_thumbnail ? 86px : 14px;
                            y: 8px;
                            width: parent.width - self.x - 48px;
                            // height: parent.height - 16px;

                            VerticalLayout {
                                spacing: 4px;

                                Text {
                                    text: item.text;
                                    color: #f5f5f7;
                                    font-size: 14px;
                                    font-weight: 400;
                                    horizontal-alignment: left;
                                    vertical-alignment: top;
                                    wrap: char-wrap;
                                    overflow: clip;
                                    height: 51px;
                                }

                                if item.note != "": Text {
                                    text: item.note;
                                    color: #6e6e73;
                                    font-size: 12px;
                                    horizontal-alignment: left;
                                    vertical-alignment: top;
                                    wrap: char-wrap;
                                    height: 20px;
                                    overflow: clip;
                                }
                            }
                        }

                        // 编辑备注按钮
                        Rectangle {
                            x: parent.width - 38px;
                            y: 8px;
                            width: 26px;
                            height: 26px;
                            visible: touch.has-hover || note_btn.has-hover || delete_btn.has-hover;
                            background: note_btn.has-hover ? #3a3a3c : transparent;
                            border-radius: 13px;

                            note_btn := TouchArea {
                                clicked => {
                                    root.open_edit_note(index);
                                }
                            }

                            Image {
                                x: 6px;
                                y: 6px;
                                width: 14px;
                                height: 14px;
                                colorize: #8e8e93;
                                source: @image-url("../../assets/icons/edit-3.svg");
                            }
                        }

                        // 删除按钮
                        Rectangle {
                            x: parent.width - 38px;
                            y: 40px;
                            width: 26px;
                            height: 26px;
                            visible: touch.has-hover || delete_btn.has-hover || note_btn.has-hover;
                            background: delete_btn.has-hover ? #3a3a3c : transparent;
                            border-radius: 13px;

                            delete_btn := TouchArea {
                                clicked => {
                                    root.item_deleted(item.id);
                                }
                            }

                            Image {
                                x: 6px;
                                y: 6px;
                                width: 14px;
                                height: 14px;
                                colorize: #8e8e93;
                                source: @image-url("../../assets/icons/trash.svg");
                            }
                        }
                    }
                }
            }

            // 快捷键提示栏
            Rectangle {
                height: 14px;
                background: transparent;

                Text {
                    text: "↑↓ 导航   Enter 粘贴   Del 删除   F2 备注   Esc 关闭   Alt + ←→ 分类";
                    color: #6e6e73;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: 100%;
                }
            }
        }
    }

    // 图片放大预览（选中图片项时显示在窗口右下角悬浮）
    if root.selected_full_image.width > 0 && root.selected_full_image.height > 0: Rectangle {
        x: root.width - 280px - 8px;
        y: root.height - 280px - 32px;
        width: 280px;
        height: 280px;
        border-radius: 14px;
        background: #1c1c1e;
        border-width: 1px;
        border-color: #3a3a3c;
        drop-shadow-blur: 8px;

        Image {
            width: 280px;
            height: 280px;
            source: root.selected_full_image;
            image-fit: contain;
        }
    }

    // 编辑备注弹窗
    if root.edit_note_id >= 0: Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        background: #00000088;

        TouchArea {
            clicked => {
                root.edit_note_cancel();
            }
        }

        Rectangle {
            x: (parent.width - 340px) / 2;
            y: (parent.height - 160px) / 2;
            width: 340px;
            height: 160px;
            background: #2c2c2e;
            border-radius: 14px;
            border-width: 1px;
            border-color: #3a3a3c;

            TouchArea { }

            Text {
                x: 20px;
                y: 20px;
                text: "编辑备注";
                color: #f5f5f7;
                font-size: 15px;
                font-weight: 600;
            }

            Rectangle {
                x: 20px;
                y: 52px;
                width: 300px;
                height: 40px;
                background: #1c1c1e;
                border-radius: 10px;
                border-width: 1px;
                border-color: #3a3a3c;

                note_edit := TextInput {
                    x: 12px;
                    width: parent.width - 24px;
                    height: 100%;
                    vertical-alignment: center;
                    text <=> root.edit_note_text;
                    font-size: 14px;
                    color: #f5f5f7;

                    init => {
                        self.focus();
                    }

                    key-pressed(event) => {
                        if (event.text == Key.Return) {
                            root.edit_note_confirm(root.edit_note_id, root.edit_note_text);
                            accept
                        } else if (event.text == Key.Escape) {
                            root.edit_note_cancel();
                            accept
                        } else {
                            reject
                        }
                    }
                }
            }

            // 取消按钮
            Rectangle {
                x: 110px;
                y: 108px;
                width: 100px;
                height: 36px;
                background: cancel_note_btn.has-hover ? #3a3a3c : #2c2c2e;
                border-radius: 10px;
                border-width: 1px;
                border-color: #48484a;

                cancel_note_btn := TouchArea {
                    clicked => {
                        root.edit_note_cancel();
                    }
                }

                Text {
                    text: "取消";
                    color: #aeaeb2;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // 保存按钮
            Rectangle {
                x: 220px;
                y: 108px;
                width: 100px;
                height: 36px;
                background: #007aff;
                border-radius: 10px;

                confirm_note_btn := TouchArea {
                    clicked => {
                        root.edit_note_confirm(root.edit_note_id, root.edit_note_text);
                    }
                }

                Text {
                    text: "保存";
                    color: #ffffff;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
