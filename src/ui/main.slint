import { ScrollView } from "std-widgets.slint";
import { SettingsWindow } from "settings.slint";

// 重新导出设置窗口组件，使其在生成代码中可用
export { SettingsWindow }

export struct HistoryItem {
    id: int,
    text: string,
    note: string,
    thumbnail: image,
    has_thumbnail: bool,
}

// 分类元数据：由 Rust 侧填充，驱动按钮渲染与键盘循环
export struct CategoryDef {
    id: string,
    label: string,
}

export component MainWindow inherits Window {
    width: 380px;
    height: 540px;
    title: "CCopy";
    // background: rgba(0,0,0,0);
    background: #15171d;
    no-frame: true;
    always-on-top: true;

    callback hide_requested();
    callback item_selected(int);
    callback item_deleted(int);
    callback search_changed(string);
    callback category_changed(string);
    callback cycle_category(int);
    callback move_selection(int);
    callback confirm_selection();
    callback panel_opened();
    callback focus_search();
    callback load_more();
    callback drag_started();
    callback dragged();
    in-out property <string> search_text;
    in-out property <string> selected_category;
    in property <[CategoryDef]> categories;
    in-out property <int> selected_id;
    in property <[HistoryItem]> history;
    in-out property <length> viewport-y;
    out property <length> visible-height: history_view.visible-height;
    out property <length> content-height: history_view.viewport-height;

    in-out property <string> edit_note_text;
    in-out property <int> edit_note_id;
    in-out property <int> edit_note_row_index;
    callback open_edit_note(int);
    callback edit_note_confirm(int, string);
    callback edit_note_cancel();

    // 打开设置面板
    callback open_settings();

    focus_search => {
        search_input.focus();
    }

    // 滚动到底部检测：定时检查 viewport-y，接近底部触发加载更多
    load_more_timer := Timer {
        interval: 200ms;
        running: root.visible-height > 0 && root.content-height > 0
            && (-root.viewport-y + root.visible-height >= root.content-height - 200px)
            && root.content-height > root.visible-height;
        triggered => {
            root.load_more();
        }
    }

    open_edit_note(row_index) => {
        root.edit_note_row_index = row_index;
        root.edit_note_id = root.history[row_index].id;
        root.edit_note_text = root.history[row_index].note;
    }

    Rectangle {
        // border-radius: 18px;
        // background: #15171d;


        drag_area := TouchArea {
            moved => {
                if (self.pressed) {
                    root.dragged();
                }
            }
            pointer-event(event) => {
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    root.drag_started();
                }
            }
        }

        FocusScope {
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.hide_requested();
                    accept
                } else if (event.text == Key.Return) {
                    root.confirm_selection();
                    accept
                } else if (event.text == Key.DownArrow) {
                    if root.history.length > 0 {
                        root.move_selection(1);
                    }
                    accept
                } else if (event.text == Key.UpArrow) {
                    if root.history.length > 0 {
                        root.move_selection(-1);
                    }
                    accept
                } else if (event.modifiers.alt && event.text == Key.RightArrow) {
                    root.cycle_category(1);
                    accept
                } else if (event.modifiers.alt && event.text == Key.LeftArrow) {
                    root.cycle_category(-1);
                    accept
                } else {
                    reject
                }
            }
        }

        VerticalLayout {
            padding: 12px;
            spacing: 16px;

            Rectangle {
                height: 34px;
                background: transparent;

                Text {
                    x: 0;
                    text: "CCopy";
                    color: white;
                    font-size: 18px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                }

                Rectangle {
                    x: parent.width - 68px;
                    width: 34px;
                    height: 34px;
                    border-radius: 10px;
                    background: settings_area.has-hover ? #3a4152 : transparent;

                    settings_area := TouchArea {
                        clicked => {
                            root.open_settings();
                        }
                    }

                    Image {
                        x: 10px;
                        y: 10px;
                        width: 14px;
                        height: 14px;
                        colorize: #d7dbea;
                        source: @image-url("../../assets/icons/settings.svg");
                    }
                }

                Rectangle {
                    x: parent.width - 34px;
                    width: 34px;
                    height: 34px;
                    border-radius: 10px;
                    background: close_area.has-hover ? #3a4152 : transparent;

                    close_area := TouchArea {
                        clicked => {
                            root.hide_requested();
                        }
                    }

                    Image {
                        x: 10px;
                        y: 10px;
                        width: 14px;
                        height: 14px;
                        colorize: #d7dbea;
                        source: @image-url("../../assets/icons/x.svg");
                    }
                }
            }

            search_area := Rectangle {
                height: 36px;
                border-radius: 8px;
                background: #20242f;
                border-width: 0;

                search_input := TextInput {
                    height: 100%;
                    x: 15px;
                    width: parent.width - 40px;
                    vertical-alignment: center;
                    text <=> root.search_text;
                    edited => {
                        root.search_changed(self.text);
                    }

                    key-pressed(event) => {
                        if (event.text == Key.DownArrow) {
                            if root.history.length > 0 {
                                root.move_selection(1);
                            }
                            accept
                        } else if (event.text == Key.UpArrow) {
                            if root.history.length > 0 {
                                root.move_selection(-1);
                            }
                            accept
                        } else if (event.modifiers.alt && event.text == Key.RightArrow) {
                            root.cycle_category(1);
                            accept
                        } else if (event.modifiers.alt && event.text == Key.LeftArrow) {
                            root.cycle_category(-1);
                            accept
                        } else if (event.text == Key.Return) {
                            root.confirm_selection();
                            accept
                        } else if (event.text == Key.Escape) {
                            root.hide_requested();
                            accept
                        } else {
                            reject
                        }
                    }
                }

                Rectangle {
                    x: parent.width - 24px - 6px;
                    width: 24px;
                    height: 24px;
                    background: search_clear_btn.has-hover ? #3a2a32 : transparent;
                    border-radius: 12px;
                    visible: search_input.text != "";

                    search_clear_btn := TouchArea {
                        clicked => {
                            root.search_text = "";
                            root.search_changed("");
                        }
                    }

                    Image {
                        x: 6px;
                        y: 6px;
                        width: 12px;
                        height: 12px;
                        colorize: #d7dbea;
                        source: @image-url("../../assets/icons/x.svg");
                    }
                }
            }

            HorizontalLayout {
                height: 30px;
                spacing: 8px;

                for cat in root.categories: Rectangle {
                    width: 56px;
                    height: 30px;
                    border-radius: 15px;
                    background: root.selected_category == cat.id ? #4d7cff : (cat_touch.has-hover ? #2d3342 : #20242f);

                    cat_touch := TouchArea {
                        clicked => {
                            root.selected_category = cat.id;
                            root.category_changed(cat.id);
                        }
                    }

                    Text {
                        text: cat.label;
                        color: root.selected_category == cat.id ? white : #c8cfdd;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            if root.history.length == 0: Text {
                text: "复制一段文本后，按 Alt+V 在这里选择历史记录。";
                color: #9aa3b8;
                font-size: 14px;
                wrap: word-wrap;
                vertical-alignment: center;
                horizontal-alignment: center;
                width: 100%;
            }

            history_view := ScrollView {
                viewport-width: 356px;
                viewport-y <=> root.viewport-y;

                VerticalLayout {
                    width: 356px;
                    spacing: 10px;

                    for item[index] in root.history: Rectangle {
                        height: 78px;
                        border-radius: 12px;
                        touch := TouchArea {
                            clicked => {
                                root.item_selected(item.id);
                            }
                        }

                        background: item.id == root.selected_id ? #36416b : (touch.has-hover ? #2d3342 : #20242f);

                        if item.has_thumbnail: Rectangle {
                            x: 10px;
                            y: 6px;
                            width: 66px;
                            height: 66px;
                            border-radius: 6px;
                            clip: true;
                            background: #20242f;

                            Image {
                                width: 66px;
                                height: 66px;
                                source: item.thumbnail;
                                image-fit: preserve;
                            }
                        }

                        Rectangle {
                            x: item.has_thumbnail ? 86px : 14px;
                            y: 6px;
                            width: parent.width - self.x - 44px;
                            height: parent.height - 12px;

                            VerticalLayout {
                                spacing: 4px;

                                Text {
                                    text: item.text;
                                    color: #eef1f8;
                                    font-size: 14px;
                                    horizontal-alignment: left;
                                    vertical-alignment: top;
                                    wrap: char-wrap;
                                    height: 48px;
                                    overflow: clip;
                                }

                                if item.note != "": Text {
                                    text: "备注: " + item.note;
                                    color: #999;
                                    font-size: 12px;
                                    horizontal-alignment: left;
                                    vertical-alignment: top;
                                    wrap: char-wrap;
                                    height: 20px;
                                    overflow: clip;
                                }
                            }
                        }

                        Rectangle {
                            x: parent.width - 34px;
                            y: 6px;
                            width: 24px;
                            height: 24px;
                            visible: touch.has-hover || delete_btn.has-hover || note_btn.has-hover;
                            background: note_btn.has-hover ? #000 : transparent;
                            border-radius: 12px;

                            note_btn := TouchArea {
                                clicked => {
                                    root.open_edit_note(index);
                                }
                            }

                            Image {
                                x: 5px;
                                y: 5px;
                                width: 14px;
                                height: 14px;
                                colorize: #ddd;
                                source: @image-url("../../assets/icons/edit-3.svg");
                            }
                        }

                        Rectangle {
                            x: parent.width - 34px;
                            y: 36px;
                            width: 24px;
                            height: 24px;
                            visible: touch.has-hover || delete_btn.has-hover || note_btn.has-hover;
                            background: delete_btn.has-hover ? #000 : transparent;
                            border-radius: 12px;

                            delete_btn := TouchArea {
                                clicked => {
                                    root.item_deleted(item.id);
                                }
                            }

                            Image {
                                x: 5px;
                                y: 5px;
                                width: 14px;
                                height: 14px;
                                colorize: #ddd;
                                source: @image-url("../../assets/icons/trash.svg");
                            }
                        }
                    }
                }
            }
        }
    }

    // Edit note dialog
    if root.edit_note_id >= 0: Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        background: #15171daa;

        TouchArea {
            clicked => {
                root.edit_note_cancel();
            }
        }

        Rectangle {
            x: (parent.width - 340px) / 2;
            y: (parent.height - 150px) / 2;
            width: 340px;
            height: 150px;
            background: #20242f;
            border-radius: 12px;

            TouchArea { }

            Text {
                x: 20px;
                y: 20px;
                text: "编辑备注";
                color: #eef1f8;
                font-size: 14px;
                font-weight: 600;
            }

            Rectangle {
                x: 20px;
                y: 50px;
                width: 300px;
                height: 40px;
                background: #15171d;
                border-radius: 8px;

                note_edit := TextInput {
                    width: parent.width - 40px;
                    height: 100%;
                    vertical-alignment: center;
                    text <=> root.edit_note_text;

                    init => {
                        self.focus();
                    }

                    key-pressed(event) => {
                        if (event.text == Key.Return) {
                            root.edit_note_confirm(root.edit_note_id, root.edit_note_text);
                            accept
                        } else if (event.text == Key.Escape) {
                            root.edit_note_cancel();
                            accept
                        } else {
                            reject
                        }
                    }
                }
            }

            Rectangle {
                x: 110px;
                y: 100px;
                width: 100px;
                height: 34px;
                background: cancel_note_btn.has-hover ? #3a4152 : #15171d;
                border-radius: 8px;

                cancel_note_btn := TouchArea {
                    clicked => {
                        root.edit_note_cancel();
                    }
                }

                Text {
                    text: "取消";
                    color: #9aa3b8;
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                x: 220px;
                y: 100px;
                width: 100px;
                height: 34px;
                background: #4d7cff;
                border-radius: 8px;

                confirm_note_btn := TouchArea {
                    clicked => {
                        root.edit_note_confirm(root.edit_note_id, root.edit_note_text);
                    }
                }

                Text {
                    text: "保存";
                    color: white;
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
